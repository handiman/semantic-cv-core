{
  "name": "semantic-cv-core",
  "version": "0.1.0",
  "description": "A schema.org‑first CV generator for developers.",
  "license": "MIT",
  "author": "Henrik Becker",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/handiman/semantic-cv.git"
  },
  "bugs": {
    "url": "https://github.com/handiman/semantic-cv/issues"
  },
  "homepage": "https://semantic.cv",
  "scripts": {
    "clean": "rimraf dist",
    "watch": "npm run build && jsonld-cv watch",
    "build": "npm run clean && tsc --project tsconfig.json",
    "test": "npm run clean && npm run build && node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=junit --test-reporter-destination=test-results.xml *.test.js && npm run test:results",
    "test:results": "xunit-viewer -r test-results.xml -o test-results.html"
  },
  "devDependencies": {
    "@types/node": "25.3.1",
    "@types/prompts": "^2.4.9",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "imports": {
    "#core/*": "./dist/*"
  }
}
